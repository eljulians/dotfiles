# Copy this file to secrets.sh and fill in your values
# secrets.sh is gitignored and will not be committed

# OpenWeather API key (get one at https://openweathermap.org/api)
export TMUX_POWERLINE_SEG_AIR_OPEN_WEATHER_API_KEY=""

# Your location for air quality
export TMUX_POWERLINE_SEG_AIR_LAT=""
export TMUX_POWERLINE_SEG_AIR_LON=""

# GitHub token for notifications (optional)
# export TMUX_POWERLINE_SEG_GITHUB_NOTIFICATIONS_TOKEN=""

# Claude usage plugin - browser session key for exact mode (not approximate)
# Get it from: claude.ai DevTools → Application → Cookies → sessionKey
# Then in tmux.conf: set -g @claude_usage_session_key "$CLAUDE_SESSION_KEY"
export CLAUDE_SESSION_KEY=""
